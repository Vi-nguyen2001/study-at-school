<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context="Assignment.FragmentScreen.CaiDatFragment"
    android:background="#FAF0E6"
    >

    <!-- TODO: Update blank fragment layout -->

   <LinearLayout
       android:layout_width="match_parent"
       android:layout_height="match_parent"
       android:orientation="vertical"
       android:gravity="center"
       >
       <TextView
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:text="Đổi Mật Khẩu"
           android:textSize="45sp"
           android:textStyle="bold"
           android:textAlignment="center"

           />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mật Khẩu hiện tại"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_margin="10dp"
            />
       <EditText
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:id="@+id/edtMkHienTai"
           android:hint="Nhập mật khẩu hiện tại"
           android:layout_margin="10dp"
           android:background="@drawable/bg_edittext"
           android:padding="20dp"
           />
       <TextView
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:text="Mật Khẩu mới"
           android:textSize="20sp"
           android:textStyle="bold"
           android:layout_margin="10dp"
           />
       <EditText
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:id="@+id/edtMkMoi"
           android:hint="Nhập mật khẩu mói"
           android:layout_margin="10dp"
           android:background="@drawable/bg_edittext"
           android:padding="20dp"
           />
       <TextView
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:text="Nhập lại Mật khẩu"
           android:textSize="20sp"
           android:textStyle="bold"
           android:layout_margin="10dp"
           />
       <EditText
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:id="@+id/edtNhaplaiMk"
           android:hint="Nhập lại mật khẩu mới"
           android:layout_margin="10dp"
           android:background="@drawable/bg_edittext"
           android:padding="20dp"
           />

       <Button
           android:id="@+id/btnDoi"
           android:layout_width="match_parent"
           android:layout_height="60dp"
           android:background="@drawable/bg_button"
           android:text="Đổi mật khẩu"
           android:layout_margin="10dp"
           app:backgroundTint="#FF3333"
           app:strokeColor="#000000"
           app:strokeWidth="2dp"
           app:cornerRadius="8dp"
           android:textStyle="bold"

           />


   </LinearLayout>



</FrameLayout>